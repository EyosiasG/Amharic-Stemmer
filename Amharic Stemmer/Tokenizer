
package main

import "fmt"

// Vehicle interface as defined in Screenshot_20260513_161239_WhatsApp.jpg
type Vehicle interface {
	LoadFull() float64
	Drive(distance float64) float64
}

// FossilCar struct as defined in Screenshot_20260513_161236_WhatsApp.jpg
type FossilCar struct {
	Name               string
	TankCapacity       int
	CurrentFuel        float64
	FuelConsumption100km float64
	PricePerLiter      float64
}

func (f *FossilCar) LoadFull() float64 {
	needed := float64(f.TankCapacity) - f.CurrentFuel
	cost := needed * f.PricePerLiter
	f.CurrentFuel = float64(f.TankCapacity)
	return cost
}

func (f *FossilCar) Drive(distance float64) float64 {
	fuelNeeded := (distance / 100) * f.FuelConsumption100km
	if f.CurrentFuel >= fuelNeeded {
		f.CurrentFuel -= fuelNeeded
		return fuelNeeded * f.PricePerLiter
	}
	return 0
}

// ElectricCar struct as defined in Screenshot_20260513_161239_WhatsApp.jpg
type ElectricCar struct {
	Name            string
	BatteryCapacity int
	CurrentLevel    float64
	FullRange       int
	PricePerKWh     float64
}

func (e *ElectricCar) LoadFull() float64 {
	needed := float64(e.BatteryCapacity) - e.CurrentLevel
	cost := needed * e.PricePerKWh
	e.CurrentLevel = float64(e.BatteryCapacity)
	return cost
}

func (e *ElectricCar) Drive(distance float64) float64 {
	// Energy consumption per km = BatteryCapacity / FullRange
	energyNeeded := distance * (float64(e.BatteryCapacity) / float64(e.FullRange))
	if e.CurrentLevel >= energyNeeded {
		e.CurrentLevel -= energyNeeded
		return energyNeeded * e.PricePerKWh
	}
	return 0
}

// driveAllVehicles function as defined in Screenshot_20260513_161239_WhatsApp.jpg
func driveAllVehicles(vehicles []Vehicle, distance float64) float64 {
	totalCost := 0.0
	for _, v := range vehicles {
		totalCost += v.Drive(distance)
	}
	return totalCost
}

func main() {
	// Example usage
	myFossil := &FossilCar{"Old Timer", 50, 10.0, 7.5, 1.50}
	myEV := &ElectricCar{"Future Ride", 75, 20.0, 400, 0.30}

	fleet := []Vehicle{myFossil, myEV}
	
	fmt.Printf("Initial load cost: %.2f\n", myFossil.LoadFull() + myEV.LoadFull())
	fmt.Printf("Total trip cost: %.2f\n", driveAllVehicles(fleet, 100.0))
}

package main

import "fmt"

type Sellable interface {
	RestockFull() float64
	Sell(quantity int) float64
}

type BookShelf struct {
	Name           string
	Capacity       int
	CurrentBooks   int
	WholesalePrice float64
	RetailPrice    float64
}

type CoffeeStand struct {
	Name         string
	BeanCapacity float64
	CurrentBeans float64
	BeansPerCup  float64
	CostPerKg    float64
	PricePerCup  float64
}

func (b *BookShelf) RestockFull() float64 {
	needed := b.Capacity - b.CurrentBooks
	cost := float64(needed) * b.WholesalePrice
	b.CurrentBooks = b.Capacity
	return cost
}

func (b *BookShelf) Sell(quantity int) float64 {
	if b.CurrentBooks < quantity {
		return 0
	}
	b.CurrentBooks -= quantity
	return float64(quantity) * b.RetailPrice
}

func (c *CoffeeStand) RestockFull() float64 {
	needed := c.BeanCapacity - c.CurrentBeans
	cost := needed * c.CostPerKg
	c.CurrentBeans = c.BeanCapacity
	return cost
}

func (c *CoffeeStand) Sell(quantity int) float64 {
	beansNeeded := float64(quantity) * c.BeansPerCup
	if c.CurrentBeans < beansNeeded {
		return 0
	}
	c.CurrentBeans -= beansNeeded
	return float64(quantity) * c.PricePerCup
}

func sellAllItems(items []Sellable, quantity int) float64 {
	totalRevenue := 0.0

	for _, item := range items {
		totalRevenue += item.Sell(quantity)
	}

	return totalRevenue
}

func main() {
	books := BookShelf{
		Name:           "Programming Books",
		Capacity:       40,
		CurrentBooks:   25,
		WholesalePrice: 12,
		RetailPrice:    25,
	}

	coffee := CoffeeStand{
		Name:         "Coffee Bar",
		BeanCapacity: 10,
		CurrentBeans: 4,
		BeansPerCup:  0.08,
		CostPerKg:    10,
		PricePerCup:  3.5,
	}

	items := []Sellable{&books, &coffee}
	quantity := 20
	totalRevenue := sellAllItems(items, quantity)
	// Output should be: Total revenue for selling 20 units from each item: $570.00
	fmt.Printf("Total revenue for selling %d units from each item: $%.2f\n", quantity, totalRevenue)
}
