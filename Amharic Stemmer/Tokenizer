package main

import (
	"fmt"
	"sync"
)

type Submission struct {
	ID      int
	Answers []string
}

type GradeResult struct {
	SubmissionID   int
	CorrectAnswers int
}

func CountCorrectAnswers(answers []string, answerKey []string) int {
	correctCount := 0

	minLength := len(answers)
	if len(answerKey) < minLength {
		minLength = len(answerKey)
	}

	for i := 0; i < minLength; i++ {
		if answers[i] == answerKey[i] {
			correctCount++
		}
	}
	return correctCount
}

func GradeSubmissions(submissions []Submission, answerKey []string) []GradeResult {
	results := make([]GradeResult, len(submissions))
	var wg sync.WaitGroup

	for i := 0; i < len(submissions); i++ {
		wg.Add(1)

		go func(idx int, sub Submission) {
			defer wg.Done()
			score := CountCorrectAnswers(sub.Answers, answerKey)

			results[idx] = GradeResult{
				SubmissionID:   sub.ID,
				CorrectAnswers: score,
			}
		}(i, submissions[i])
	}

	wg.Wait()
	return results
}

func TotalCorrectAnswers(results []GradeResult) int {
	total := 0
	for _, res := range results {
		total += res.CorrectAnswers
	}
	return total
}

func main() {
	answerKey := []string{"A", "C", "B", "D"}
	submissions := []Submission{
		{ID: 203, Answers: []string{"A", "C", "B", "D"}},
		{ID: 101, Answers: []string{"A", "A", "B", "D"}},
		{ID: 307, Answers: []string{"D", "C", "C", "D"}},
	}

	results := GradeSubmissions(submissions, answerKey)
	total := TotalCorrectAnswers(results)

	for _, result := range results {
		fmt.Printf("Submission %d: %d correct answers\n", result.SubmissionID, result.CorrectAnswers)
	}
	fmt.Printf("Total correct answers: %d\n", total)
}


package main

import (
	"fmt"
	"strings"
	"sort"
	"sync"
)

type Job struct {
	ID   int
	Text string
}

type Result struct {
	JobID     int
	WordCount int
}

func CountWords(text string) int {
	return len(strings.Fields(text))
}

func ProcessJobs(jobs []Job) []Result {
	results := make([]Result, len(jobs))
	var wg sync.WaitGroup

	for i := 0; i < len(jobs); i++ {
		wg.Add(1)

		go func(idx int, j Job) {
			defer wg.Done()
			
			results[idx] = Result{
				JobID:     j.ID,
				WordCount: CountWords(j.Text),
			}
		}(i, jobs[i])
	}

	wg.Wait()

	sort.Slice(results, func(i, j int) bool {
		return results[i].JobID < results[j].JobID
	})

	return results
}

func TotalWords(results []Result) int {
	total := 0
	for _, res := range results {
		total += res.WordCount
	}
	return total
}

func main() {
	jobs := []Job{
		{ID: 3, Text: "Go concurrency is fun"},
		{ID: 1, Text: "Hello world Go"},
		{ID: 2, Text: "Slices channels and goroutines"},
	}

	results := ProcessJobs(jobs)
	total := TotalWords(results)

	for _, result := range results {
		fmt.Printf("Job %d: %d words\n", result.JobID, result.WordCount)
	}
	fmt.Printf("Total words: %d\n", total)
}
